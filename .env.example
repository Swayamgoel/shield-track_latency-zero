# ─────────────────────────────────────────────────────────
# ShieldTrack Root Environment File
# ─────────────────────────────────────────────────────────
# This is a centralized .env file that powers all Monorepo apps.
# Mobile, API, Admin Portal, and Python ML Backend all read from here.

# =================
# Supabase Backend
# =================
# Public Anon Key (Safe to expose to Mobile / Web)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGx...
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGx...

# Python Backend / Service Worker (SECRET! DO NOT EXPOSE TO APPS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGx...

# =================
# Third Party APIs
# =================
# For live traffic delay in the ML Backend
GOOGLE_MAPS_API_KEY=mock

# =================
# ML Model Overrides
# =================
MODEL_PATH=eta_model.pkl
BUS_STALE_THRESHOLD_SECONDS=60
DEBUG=true

# =================
# Seeding / Admin Init
# =================
# Initial Admin Auth credentials for bootstrapping (SECRET!)
# Used by: scripts/seed_admin.mjs
ADMIN_EMAIL=admin@shield.track.edu
ADMIN_PASSWORD=********
